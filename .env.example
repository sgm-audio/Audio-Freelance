# ── Freelance Acquisition System ──
# Copy to .env and fill in your actual API keys

# Niches (comma-separated)
PREFERRED_NICHES=plugin_dev,reaper_scripts,rust_audio,audio_ml,game_audio_dev

# Minimums
MIN_RATE_CAD=3000
HOURLY_FLOOR_CAD=150

# Scoring thresholds
HOT_THRESHOLD=10
WARM_THRESHOLD=5

# ChromaDB
CHROMA_COLLECTION_LEADS=freelance_leads
CHROMA_COLLECTION_OUTREACH=freelance_outreach_log
# Override to isolate tests: LEADS_DATA_DIR=/tmp/test-chroma
# LEADS_DATA_DIR=

# Cold-lead rotation (age in days)
# COLD_ROTATION_DAYS=3

# Archive directory (default: leads/data/archive)
# LEADS_ARCHIVE_DIR=

# Allow test-source leads in production (only for test suites!)
# LEADS_ALLOW_TEST_LEADS=1

# Embedding
EMBEDDING_MODEL=nomic-embed-text
DEDUP_SIMILARITY_THRESHOLD=0.92

# ── Search APIs (REQUIRED — paste your real keys) ──
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=

# ── API Authentication ──
# Set a key here to protect all API endpoints (except /health).
# Leave empty for local dev (no auth required).
API_KEY=

# ── CORS ──
# Comma-separated additional origins beyond localhost defaults.
# Example: https://audio-freelance.example.com
CORS_ORIGINS=

# ── Error tracking (optional) ──
# Get your DSN from https://sentry.io
SENTRY_DSN=
ENVIRONMENT=development

# ── Ollama (Local) ──
OLLAMA_HOST=http://localhost:11434

# ── SGM Outreach Engine (OUTREACH_BUILD_SPEC §10) ──
# Never commit real secrets. Copy to .env and fill locally.
DEEPSEEK_API_KEY=
RESEND_API_KEY=
# Verified sender (Resend domain). Empty falls back to scott@sgmstudios.ca in send config.
SGM_OUTREACH_FROM_EMAIL=scott@sgmstudios.ca
SGM_OUTREACH_FROM_NAME=Scott
SGM_OUTREACH_SENDER_NAME=Scott
# Public base URL for CASL unsubscribe links
SGM_OUTREACH_UNSUBSCRIBE_BASE_URL=http://127.0.0.1:8791/unsubscribe
SGM_OUTREACH_UNSUB_SECRET=
# CASL identity (appended by send/, never by the LLM)
SGM_OUTREACH_BUSINESS_NAME=SGM Studios
SGM_OUTREACH_BUSINESS_CONTACT=scott@sgmstudios.ca
# SQLite path (default: ./data/outreach.sqlite)
SGM_OUTREACH_DB=
# Staging: set to 1 to redirect sends to the sink address (required until go-live)
SGM_OUTREACH_STAGING=1
SGM_OUTREACH_SINK_EMAIL=
# Reply/bounce webhook listener (sgm-outreach webhook serve)
SGM_OUTREACH_WEBHOOK_HOST=127.0.0.1
SGM_OUTREACH_WEBHOOK_PORT=8787
# n8n webhook for daily PENDING_APPROVAL digest (Telegram/email bridge)
N8N_APPROVAL_WEBHOOK_URL=
# Telegram bot placeholders (optional; use with n8n or direct notify)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

